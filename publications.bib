@article{parkPredictionInterpretationPolymer2022b,
  title = {Prediction and {{Interpretation}} of {{Polymer Properties Using}} the {{Graph Convolutional Network}}},
  author = {Park, Jaehong and Shim, Youngseon and Lee, Franklin and Rammohan, Aravind and Goyal, Sushmit and Shim, Munbo and Jeong, Changwook and Kim, Dae Sin},
  year = 2022,
