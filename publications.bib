  title = {Analyzing the {{Contact-Doping Effect}} in {{In}}{$_{2}$}{{O}}{$_3$} {{FETs}}: {{Unveiling}} the {{Mechanisms Behind}} the {{Threshold-Voltage Roll-Off}} in {{Oxide Semiconductor Transistors}}},
  shorttitle = {Analyzing the {{Contact-Doping Effect}} in {{In}}{$_{2}$}{{O}}{$_3$} {{FETs}}},
  author = {Lin, Jian-Yu and Niu, Chang and Lin, Zehao and Lee, Sumi and Kim, Taehyun and Lee, Jungho and Liu, Chang and Lu, Juanjuan and Wang, Haiyan and Alam, Muhammad Ashraful and Jeong, Changwook and Ye, Peide D.},
  year = 2025,
  month = jun,
  journal = {IEEE Transactions on Electron Devices},
  volume = {72},
  number = {6},
  pages = {3004--3011},
  issn = {1557-9646},
  doi = {10.1109/TED.2025.3564265},
  urldate = {2025-12-26},
  abstract = {In this work, the contact-doping effect (CDE) and its impact on the threshold voltage ( V\_\textbackslash text T ) roll-off in indium oxide (In2O3) field-effect transistors (FETs) are systematically studied. By analyzing the long channel length ( L \_\textbackslash text ch ) and short L\_\textbackslash text ch devices separately using a modified transfer length method (TLM), \textbackslash boldsymbol \textbackslash Delta L can be extracted to quantify the CDE. The correlation between \textbackslash Delta L and the L\_\textbackslash text ch at which V\_\textbackslash text T roll-off occurs suggests that CDE may be a key factor contributing to the V\_\textbackslash text T roll-off in In2O3 transistors. Next, the underlying mechanisms of CDE are investigated. It is found that oxygen scavenging reactions (OSRs) during the deposition of source/drain (S/D) metals on the In2O3 channel is one of the reasons behind CDE. S/D metals can scavenge oxygen atoms from In2O3, creating oxygen vacancies and increasing the carrier density near the S/D regions. Additionally, the Schottky barrier height ( \textbackslash boldsymbol \textbackslash Phi \_\textbackslash text SB ) of metal/In2O3 contacts might also influence the CDE: a positive \textbackslash boldsymbol \textbackslash Phi \_\textbackslash text SB depletes carriers, while a negative \textbackslash boldsymbol \textbackslash Phi \_\textbackslash text SB accumulates them in the In2O3 channel under the S/D. This study provides a new approach to investigating CDE and highlights its critical role in understanding the V\_\textbackslash text T roll-off in oxide semiconductor (OS) transistors.},
  keywords = {Charge carrier density,contact-doping effect (CDE),Electrons,Field effect transistors,Fitting,indium oxide (In2O3),Logic gates,Metals,Nickel,oxygen scavenging reaction (OSR),Resistance,Schottky barrier height,Thin film transistors,Threshold voltage,threshold voltage roll-off},
  file = {C:\Users\jeong\SynologyDrive\zotero_files\Lin et al. - 2025 - Analyzing the Contact-Doping Effect in In₂O₃ FETs Unveiling the Mechanisms Behind the Threshold-Vol.pdf}
}

@inproceedings{linEnhancementIn2O3FieldEffect2024a,
  title = {Enhancement of {{In2O3 Field-Effect Mobility Up To}} 152 Cm2.{{V}}-1{$\cdot$}s-{{1Using HZO-Based Higher-k Linear Dielectric}}},
  booktitle = {2024 {{IEEE Symposium}} on {{VLSI Technology}} and {{Circuits}} ({{VLSI Technology}} and {{Circuits}})},
  author = {Lin, Zehao and Niu, Chang and Jang, Hyeongjun and Kim, Taehyun and Zhang, Yizhi and Wang, Haiyan and Jeong, Changwook and Ye, Peide D.},
  year = 2024,
  month = jun,
  pages = {1--2},
  issn = {2158-9682},
  doi = {10.1109/VLSITechnologyandCir46783.2024.10631497},
  urldate = {2026-03-12},
  abstract = {In this work, we report high-performance atomic-layer-deposited (ALD) In2O3 thin-film transistor (TFT) using HfxZr1-xO2 (HZO) as a linear higher-k dielectric. By properly inserting a thin Al2O3 layer between two HZO layers with asymmetric thickness and post-deposition annealing (PDA) of the HZO-Al2O3-HZO (HZAHZO) stack capped with In2O3, the k value of the linear dielectric is boosted to 30. This results in an equivalent oxide thickness (EOT) of 1.9 nm with physical thickness of 15.5 nm and meanwhile In2O3 field-effect mobility (\textbackslash mu\_textFE) is boosted to 152 cm2.V-1.s-1, simultaneously. Such enhancements enable high-performance TFTs with record saturation current (Isat) exceeding 2\textbackslash{} \textbackslash textmA/\textbackslash mu\textbackslash mathrmm with a channel length (Lch) of 1\textbackslash{} \textbackslash mu\textbackslash mathrmm, and maximum current (Imax) reaches 7\textbackslash{} \textbackslash textmA/\textbackslash mu\textbackslash mathrmm with Lch of 30 nm. Higher-k dielectrics also enhance the electrostatic control of the channel with negligible hysteresis, on/off ratio over 1011, and drain-induced barrier lowering (DIBL) less than 40 mV/V at Lch of 35 nm. This work demonstrates a promising and straightforward methodology to enhance the mobility of oxide semiconductor (OS) channel by using linear higher-k dielectrics.},
  keywords = {Annealing,Atomic layer deposition,Dielectrics,Electrostatics,Performance evaluation,Thin film transistors,Very large scale integration},
  file = {C:\Users\jeong\SynologyDrive\zotero_files\Lin et al. - 2024 - Enhancement of In2O3 Field-Effect Mobility Up To 152 cm2.V−1·s−1Using HZO-Based Higher-k Linear Diel.pdf}
}

@article{linFirstDemonstrationTopGate2024,
