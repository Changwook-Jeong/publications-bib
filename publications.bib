  author = {Huh, In and Islam, Mir Md Fahimul and Jeong, Changwook and Alam, Muhammad A.},
  year = 2026,
  journal = {IEEE Electron Device Letters},
  pages = {1--1},
  issn = {1558-0563},
  doi = {10.1109/LED.2026.3701783},
  urldate = {2026-06-26},
  abstract = {The subthreshold swing (SS) is expected to scale linearly with temperature, SSB=(kBT/q)ln10, yet experimental data from cryogenic UTB (Si, MoS2, and oxide) MOSFETs exhibit anomalous temperature-dependent nonlinearities characterized by negative differential SS and multiple plateaus. Here we use the Landauer formulation to rigorously derive the scaling relationship SS=SSB{$\bullet$}1+{$\gamma$}(TR/T)T/TW to capture the universality and robustness of SS anomalies reported in the literature to date. The temperature scales (TW,TR) are related to the intrinsic properties of the band-tail states and reference current, and as such, can be used as a diagnostic quality monitor of as-fabricated and stress-degraded MOSFET.},
  keywords = {asymptotic analysis,band-tail states,cryogenic behavior,Current,Electron devices,Electrons,Landauer transport,Modeling,Subthreshold swing,Tail,Temperature},
  file = {C:\Users\jeong\SynologyDrive\zotero_files\Huh et al. - 2026 - A Scaling Theory for the Nonlinear Subthreshold Behavior of Cryogenic Ultrathin Body MOSFETs.pdf}
