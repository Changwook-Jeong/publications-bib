  author = {Lee, Seokki and Park, Min-Chul and Hong, Giyong and Jeong, Changwook},
  year = 2026,
  month = apr,
  urldate = {2026-05-05},
  abstract = {PDE surrogate models such as FNO and PINN struggle to predict solutions across inputs with diverse physical units and scales, limiting their out-of-distribution (OOD) generalization. We propose a \$\textbackslash pi\$-invariant test-time projection that aligns test inputs with the training distribution by solving a log-space least squares problem that preserves Buckingham \$\textbackslash pi\$-invariants. For PDEs with multidimensional spatial fields, we use geometric representative \$\textbackslash pi\$-values to compute distances and project inputs, overcoming degeneracy and singular points that limit prior \$\textbackslash pi\$-methods. To accelerate projection, we cluster the training set into K clusters, reducing the complexity from O(MN) to O(KN) for the M training and N test samples. Across wide input scale ranges, tests on 2D thermal conduction and linear elasticity achieve an average MAE reduction up to \$\textbackslash approx 91\textbackslash\textbackslash\%\$ with minimal overhead. This training-free, model-agnostic method is expected to apply to more diverse PDE-based simulations.},
  langid = {english},
  file = {C:\Users\jeong\SynologyDrive\zotero_files\Lee et al. - 2025 - Buckingham $pi$-Invariant Test‑Time Projection for Robust PDE Surrogate Modeling.pdf}
}

