  author = {Lin, Jian-Yu and Zhang, Zhuocheng and Lin, Zehao and Niu, Chang and Zhang, Yizhi and Zhang, Yifan and Kim, Taehyun and Jang, H. and Sung, C. and Hong, M. and Lee, S. M. and Lee, T. and Cho, M. H. and Ha, D. and Jeong, Changwook and Wang, Haiyan and Alam, M. A. and Ye, Peide D.},
